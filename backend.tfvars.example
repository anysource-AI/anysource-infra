# ========================================
# TERRAFORM BACKEND CONFIGURATION
# ========================================
# Copy this file to `backend.tfvars` and customize for your deployment.
# Use with: terraform init -backend-config=backend.tfvars

# S3 Backend Configuration
bucket  = "your-terraform-state-bucket"
key     = "anysource/terraform.tfstate"
region  = "us-east-1"

# Optional: AWS Profile (if not using default)
# profile = "your-aws-profile"

# Optional: State Locking with DynamoDB
# dynamodb_table = "terraform-state-lock"

# Optional: Server-side Encryption
# encrypt = true
# kms_key_id = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"

# ========================================
# USAGE EXAMPLES
# ========================================
# 
# Initialize with S3 backend:
#   terraform init -backend-config=backend.tfvars
# 
# Initialize without backend (local state):
#   terraform init -backend=false
# 
# Reconfigure backend:
#   terraform init -backend-config=backend.tfvars -reconfigure
# 